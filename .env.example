# Server-only (Vercel → Environment Variables). Never expose the service role key to the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Optional: geocode route uses Google when set; otherwise OpenStreetMap Nominatim.
# GOOGLE_MAPS_GEOCODING_API_KEY=
